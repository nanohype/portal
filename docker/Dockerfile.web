FROM node:24-alpine AS builder

WORKDIR /app
# .npmrc carries legacy-peer-deps=true (openapi-typescript pins a conservative
# typescript ^5 peer; the app is on TS 6). Without copying it, `npm ci` ERESOLVEs
# in the container even though it resolves locally.
COPY web/package.json web/package-lock.json web/.npmrc ./
RUN npm ci

COPY web/ .
RUN npm run build

FROM nginxinc/nginx-unprivileged:1.30-alpine
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 8080
